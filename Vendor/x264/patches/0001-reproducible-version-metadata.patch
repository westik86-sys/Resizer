From: Resizer contributors
Subject: [PATCH] Allow pinned version metadata without a Git checkout

The release source is a deterministic git archive and therefore has no .git
directory. Accept an explicitly pinned revision and seven-character commit ID
from the reproducible build script so the compiled library carries the same
version metadata as a build from the pinned upstream checkout.

--- a/version.sh
+++ b/version.sh
@@ -6,7 +6,19 @@ api="$(grep '#define X264_BUILD' < x264.h | sed 's/^.* \([1-9][0-9]*\).*$/\1/')"
 ver="x"
 version=""
 
-if [ -d .git ] && command -v git >/dev/null 2>&1 ; then
+if [ -n "${X264_PINNED_REV:-}" ] || [ -n "${X264_PINNED_COMMIT:-}" ] ; then
+    case "${X264_PINNED_REV:-}" in
+        ''|*[!0-9]*) exit 1 ;;
+    esac
+    case "${X264_PINNED_COMMIT:-}" in
+        ???????) ;;
+        *) exit 1 ;;
+    esac
+    echo "#define X264_REV $X264_PINNED_REV"
+    echo "#define X264_REV_DIFF 0"
+    ver="$X264_PINNED_REV $X264_PINNED_COMMIT"
+    version=" r$ver"
+elif [ -d .git ] && command -v git >/dev/null 2>&1 ; then
     localver="$(($(git rev-list HEAD | wc -l)))"
     if [ "$localver" -gt 1 ] ; then
         ver_diff="$(($(git rev-list origin/master..HEAD | wc -l)))"
