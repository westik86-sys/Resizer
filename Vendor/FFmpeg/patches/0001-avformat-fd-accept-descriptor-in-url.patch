+
+static int64_t fd_seek(URLContext *h, int64_t pos, int whence)
+{
+    FileContext *c = h->priv_data;
+    int64_t base;
+    int64_t target;
+    struct stat st;
+
+    if (h->is_streamed)
+        return file_seek(h, pos, whence);
+
+    if (whence == AVSEEK_SIZE)
+        return file_seek(h, pos, whence);
+
+    switch (whence) {
+    case SEEK_SET:
+        base = 0;
+        break;
+    case SEEK_CUR:
+        base = c->fd_pos;
+        break;
+    case SEEK_END:
+        if (fstat(c->fd, &st) < 0)
+            return AVERROR(errno);
+        base = st.st_size;
+        break;
+    default:
+        return AVERROR(EINVAL);
+    }
+
+    if ((pos > 0 && base > INT64_MAX - pos) ||
+        (pos < 0 && base < INT64_MIN - pos))
+        return AVERROR(EOVERFLOW);
+
+    target = base + pos;
+    if (target < 0)
+        return AVERROR(EINVAL);
+
+    c->fd_pos = target;
+    return target;
+}
