+        return file_read(h, buf, size);
+
+    size = FFMIN(size, c->blocksize);
+    if (c->fd_pos > INT64_MAX - size)
+        return AVERROR(EOVERFLOW);
+
+    ret = pread(c->fd, buf, size, c->fd_pos);
+    if (ret == 0)
